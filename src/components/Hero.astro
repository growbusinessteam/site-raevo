---
import { site } from "../data/site";

interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
}

const {
  eyebrow = "Sistemas inteligentes",
  title = "Inteligencia que conecta. Estrategia que transforma.",
  description =
    "A Raevo desenha automacoes, dashboards e sistemas sob medida para empresas que precisam crescer com clareza operacional.",
} = Astro.props;
---

<section class="hero">
  <div class="hero-content">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p class="hero-copy">{description}</p>
    <div class="hero-actions">
      <a class="button" href={site.ctaHref}>{site.ctaLabel}</a>
      <a class="button secondary" href="/solucoes">Ver solucoes</a>
    </div>
  </div>
  <div class="hero-panel" aria-label="Preview visual Raevo">
    <img src="/assets/brand/raevo-logo-champagne-cyan.png" alt="" />
    <div class="signal">
      <span></span>
      <strong>+24,6%</strong>
      <small>crescimento sustentavel monitorado</small>
    </div>
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.78fr);
    gap: clamp(32px, 7vw, 92px);
    align-items: center;
    min-height: calc(100vh - 92px);
    width: var(--container);
    margin: 0 auto;
    padding: 72px 0 48px;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(3.2rem, 8.8vw, 8.7rem);
    font-weight: 500;
    line-height: 0.9;
  }

  h1 :global(.accent) {
    color: var(--color-cian);
  }

  .hero-copy {
    max-width: 620px;
    margin: 28px 0 0;
    color: rgba(31, 31, 31, 0.72);
    font-size: clamp(1.08rem, 1.7vw, 1.35rem);
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 34px;
  }

  .hero-panel {
    position: relative;
    display: grid;
    min-height: 520px;
    place-items: center;
    overflow: hidden;
    border: 1px solid rgba(199, 169, 122, 0.36);
    border-radius: 8px;
    background:
      linear-gradient(135deg, rgba(31, 31, 31, 0.92), rgba(31, 31, 31, 0.74)),
      url("/assets/brand/raevo-brandboard.png") center / cover;
    box-shadow: 0 24px 80px rgba(31, 31, 31, 0.22);
  }

  .hero-panel::before {
    position: absolute;
    inset: 12%;
    border: 1px solid rgba(199, 169, 122, 0.28);
    content: "";
  }

  .hero-panel img {
    position: relative;
    width: min(72%, 430px);
  }

  .signal {
    position: absolute;
    right: 24px;
    bottom: 24px;
    width: min(240px, calc(100% - 48px));
    padding: 18px;
    border: 1px solid rgba(0, 184, 198, 0.38);
    border-radius: 8px;
    background: rgba(31, 31, 31, 0.82);
    color: var(--color-pedra);
  }

  .signal span {
    display: block;
    width: 48px;
    height: 4px;
    margin-bottom: 18px;
    background: var(--color-cian);
  }

  .signal strong {
    display: block;
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--color-cian);
  }

  .signal small {
    color: rgba(233, 228, 218, 0.72);
  }

  @media (max-width: 920px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .hero-panel {
      min-height: 360px;
    }
  }
</style>
